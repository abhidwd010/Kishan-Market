# ─── App ───────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ──────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kisanmarket
DATABASE_POOL_MAX=20

# ─── Redis (cache + socket adapter + rate limiter) ───
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string_in_prod
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── OTP / SMS (MSG91) ─────────────────────
MSG91_API_KEY=your_msg91_key
MSG91_SENDER_ID=KISANM
MSG91_OTP_TEMPLATE_ID=your_template_id
OTP_BYPASS=true   # dev only — set to false in prod, uses 123456

# ─── Razorpay ──────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxx

# ─── Cloudinary ────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=xxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxx

# ─── Firebase (push notifications) ─────────
FIREBASE_PROJECT_ID=kisanmarket
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Frontend (Next.js) ───────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_RAZORPAY_KEY=rzp_test_xxxxxxxxx
NEXT_PUBLIC_CLOUDINARY_CLOUD=your_cloud
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
